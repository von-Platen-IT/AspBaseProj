@page
@model AspBaseProj.Presentation.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4"><i class="bi bi-speedometer2"></i> Admin Dashboard</h2>

<!-- Stats Overview -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card admin-card text-center">
            <div class="card-body">
                <i class="bi bi-people display-6 text-primary"></i>
                <h3 class="mt-2">@Model.Stats.TotalUsers</h3>
                <p class="text-muted mb-0">Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card admin-card text-center">
            <div class="card-body">
                <i class="bi bi-file-earmark-text display-6 text-success"></i>
                <h3 class="mt-2">@Model.Stats.TotalPosts</h3>
                <p class="text-muted mb-0">Total Posts</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card admin-card text-center">
            <div class="card-body">
                <i class="bi bi-eye display-6 text-info"></i>
                <h3 class="mt-2">@Model.Stats.PublishedPosts</h3>
                <p class="text-muted mb-0">Published</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card admin-card text-center">
            <div class="card-body">
                <i class="bi bi-hourglass-split display-6 text-warning"></i>
                <h3 class="mt-2">@Model.Stats.PendingComments</h3>
                <p class="text-muted mb-0">Pending Comments</p>
            </div>
        </div>
    </div>
</div>

<!-- Navigation Cards -->
<div class="row g-3">
    <div class="col-md-3">
        <a href="/admin/moderation" class="card admin-card text-decoration-none">
            <div class="card-body text-center">
                <i class="bi bi-shield-check display-6 text-warning"></i>
                <h5 class="mt-2 text-dark">Moderation Queue</h5>
                <p class="text-muted small">Approve or reject guest comments</p>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/admin/users" class="card admin-card text-decoration-none">
            <div class="card-body text-center">
                <i class="bi bi-people-fill display-6 text-primary"></i>
                <h5 class="mt-2 text-dark">User Management</h5>
                <p class="text-muted small">Manage users and groups</p>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/admin/content" class="card admin-card text-decoration-none">
            <div class="card-body text-center">
                <i class="bi bi-folder2-open display-6 text-success"></i>
                <h5 class="mt-2 text-dark">Content Management</h5>
                <p class="text-muted small">Manage all posts and comments</p>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/admin/settings" class="card admin-card text-decoration-none">
            <div class="card-body text-center">
                <i class="bi bi-gear display-6 text-secondary"></i>
                <h5 class="mt-2 text-dark">System Settings</h5>
                <p class="text-muted small">Configure blog settings</p>
            </div>
        </a>
    </div>
</div>

<!-- Pending Comments Widget -->
@if (Model.PendingComments.Count > 0)
{
    <div class="mt-4">
        <h5><i class="bi bi-hourglass-split"></i> Pending Comments</h5>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Guest</th>
                        <th>Comment</th>
                        <th>Post</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var comment in Model.PendingComments.Take(5))
                    {
                        <tr>
                            <td>@comment.GuestName</td>
                            <td>@(comment.Content.Length > 50 ? comment.Content.Substring(0, 50) + "..." : comment.Content)</td>
                            <td>@comment.PostTitle</td>
                            <td>@comment.CreatedAt.ToString("MMM dd")</td>
                            <td>
                                <a href="/admin/moderation" class="btn btn-sm btn-outline-primary">Review</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
