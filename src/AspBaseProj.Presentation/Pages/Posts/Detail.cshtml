@page "/posts/{slug}"
@model AspBaseProj.Presentation.Pages.Posts.DetailModel
@using AspBaseProj.Presentation.Authorization
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@{
    ViewData["Title"] = Model.Post.Title;
    var canEdit = User.Identity?.IsAuthenticated == true && await AuthorizationService.AuthorizeAsync(User, Policies.AuthorOrAdmin) is { Succeeded: true };
}

<article>
    <h1 class="mb-3">@Model.Post.Title</h1>
    <div class="text-muted mb-4">
        <i class="bi bi-person"></i> @Model.Post.AuthorName
        @if (Model.Post.PublishedAt.HasValue)
        {
            <span class="mx-2">|</span>
            <i class="bi bi-calendar"></i> @Model.Post.PublishedAt.Value.ToString("MMM dd, yyyy")
        }
        <span class="mx-2">|</span>
        <i class="bi bi-eye"></i> @Model.Post.ViewCount views
        @if (canEdit)
        {
            <span class="mx-2">|</span>
            <a asp-page="/Posts/Edit" asp-route-slug="@Model.Post.Slug" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                <i class="bi bi-trash"></i> Delete
            </button>
        }
    </div>

    <div class="post-content mb-4">
        @Html.Raw(Model.Post.ContentHtml)
    </div>

    @if (Model.Post.SocialLinks.Count > 0)
    {
        <h5 class="mb-3"><i class="bi bi-link-45deg"></i> Related Links</h5>
        <div class="row g-3 mb-4">
            @foreach (var link in Model.Post.SocialLinks.OrderBy(s => s.DisplayOrder))
            {
                <div class="col-md-6">
                    <a href="@link.Url" target="_blank" rel="noopener noreferrer" class="social-link-card">
                        <span class="platform-icon">
                            @switch (link.Platform?.ToLowerInvariant())
                            {
                                case "youtube": <i class="bi bi-youtube text-danger"></i> break;
                                case "twitter":
                                case "x": <i class="bi bi-twitter-x"></i> break;
                                case "vimeo": <i class="bi bi-film text-info"></i> break;
                                case "github": <i class="bi bi-github"></i> break;
                                case "linkedin": <i class="bi bi-linkedin text-primary"></i> break;
                                default: <i class="bi bi-link-45deg"></i> break;
                            }
                        </span>
                        <div>
                            <div class="fw-bold">@(link.Title ?? link.Platform ?? "External Link")</div>
                            <small class="text-muted">@link.Url</small>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</article>

<hr class="my-4" />

<!-- Comment Section -->
<section id="comments">
    <h3 class="mb-3"><i class="bi bi-chat-dots"></i> Comments (@Model.Comments.Count)</h3>

    <!-- Comment Form -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="post" asp-page-handler="AddComment">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PostId" value="@Model.Post.Id" />
                <input type="hidden" name="PostSlug" value="@Model.Post.Slug" />
                <input type="hidden" id="ParentCommentId" name="ParentCommentId" value="" />

                @if (!User.Identity?.IsAuthenticated ?? true)
                {
                    <div class="row mb-2">
                        <div class="col-md-6">
                            <label class="form-label">Your Name *</label>
                            <input name="GuestName" class="form-control" required maxlength="100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Your Email *</label>
                            <input name="GuestEmail" type="email" class="form-control" required maxlength="200" />
                        </div>
                    </div>
                    <div class="alert alert-info small py-1">
                        <i class="bi bi-info-circle"></i> Guest comments require moderator approval before being visible.
                    </div>
                }

                <div class="mb-2">
                    <label class="form-label">Comment *</label>
                    <textarea name="Content" class="form-control" rows="3" required maxlength="5000"></textarea>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <button type="button" class="btn btn-sm btn-link text-decoration-none" onclick="document.getElementById('ParentCommentId').value=''" id="replyCancelBtn" style="display:none;">
                        Cancel reply
                    </button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-send"></i> Post Comment</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Comment Thread -->
    @if (Model.Comments.Count == 0)
    {
        <p class="text-muted">No comments yet. Be the first to comment!</p>
    }
    else
    {
        <ul class="comment-thread">
            @await Html.PartialAsync("_CommentTree", Model.Comments)
        </ul>
    }
</section>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Post</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this post? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page-handler="DeletePost" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="PostId" value="@Model.Post.Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function replyTo(commentId) {
            document.getElementById('ParentCommentId').value = commentId;
            document.getElementById('replyCancelBtn').style.display = 'inline-block';
            document.querySelector('#comments form').scrollIntoView({ behavior: 'smooth' });
        }
    </script>
}
