@page "/posts/{slug}"
@model AspBaseProj.Presentation.Pages.Posts.DetailModel
@using AspBaseProj.Presentation.Authorization
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@{
    ViewData["Title"] = Model.Post.Title;
    var canEdit = User.Identity?.IsAuthenticated == true && await AuthorizationService.AuthorizeAsync(User, Policies.AuthorOrAdmin) is { Succeeded: true };
}

<article>
    <h1 class="mb-3">@Model.Post.Title</h1>
    <div class="text-muted mb-4">
        <i class="bi bi-person"></i> @Model.Post.AuthorName
        @if (Model.Post.PublishedAt.HasValue)
        {
            <span class="mx-2">|</span>
            <i class="bi bi-calendar"></i> @Model.Post.PublishedAt.Value.ToString("MMM dd, yyyy")
        }
        <span class="mx-2">|</span>
        <i class="bi bi-eye"></i> @Model.Post.ViewCount views
        @if (canEdit)
        {
            <span class="mx-2">|</span>
            <a asp-page="/Posts/Edit" asp-route-slug="@Model.Post.Slug" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                <i class="bi bi-trash"></i> Delete
            </button>
        }
    </div>

    <div class="post-content mb-4">
        @Html.Raw(Model.Post.ContentHtml)
    </div>

    @if (Model.Post.SocialLinks.Count > 0)
    {
        <h5 class="mb-3"><i class="bi bi-link-45deg"></i> Related Links</h5>
        <div class="row g-3 mb-4">
            @foreach (var link in Model.Post.SocialLinks.OrderBy(s => s.DisplayOrder))
            {
                <div class="col-md-6">
                    <a href="@link.Url" target="_blank" rel="noopener noreferrer" class="social-link-card">
                        <span class="platform-icon">
                            @switch (link.Platform?.ToLowerInvariant())
                            {
                                case "youtube": <i class="bi bi-youtube text-danger"></i> break;
                                case "twitter":
                                case "x": <i class="bi bi-twitter-x"></i> break;
                                case "vimeo": <i class="bi bi-film text-info"></i> break;
                                case "github": <i class="bi bi-github"></i> break;
                                case "linkedin": <i class="bi bi-linkedin text-primary"></i> break;
                                default: <i class="bi bi-link-45deg"></i> break;
                            }
                        </span>
                        <div>
                            <div class="fw-bold">@(link.Title ?? link.Platform ?? "External Link")</div>
                            <small class="text-muted">@link.Url</small>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    <!-- Post Voting -->
    <div class="d-flex align-items-center gap-3 mt-3 mb-2">
        <button type="button" class="btn btn-sm btn-outline-success vote-btn @(User.Identity?.IsAuthenticated == true ? "" : "disabled")"
                onclick="voteOnPost('@Model.Post.Id', true)" id="postUpvoteBtn-@Model.Post.Id"
                title="Upvote">
            <i class="bi bi-hand-thumbs-up"></i> <span id="postUpvoteCount-@Model.Post.Id">@Model.Post.UpvoteCount</span>
        </button>
        <button type="button" class="btn btn-sm btn-outline-danger vote-btn @(User.Identity?.IsAuthenticated == true ? "" : "disabled")"
                onclick="voteOnPost('@Model.Post.Id', false)" id="postDownvoteBtn-@Model.Post.Id"
                title="Downvote">
            <i class="bi bi-hand-thumbs-down"></i> <span id="postDownvoteCount-@Model.Post.Id">@Model.Post.DownvoteCount</span>
        </button>
        <small class="text-muted">Vote on this post (logged in users only)</small>
    </div>
</article>

<hr class="my-4" />

<!-- Comment Section -->
<section id="comments">
    <h3 class="mb-3"><i class="bi bi-chat-dots"></i> Comments (@Model.Comments.Count)</h3>

    @{
        // Set ViewData for use in nested _CommentTree partials
        ViewData["PostId"] = Model.Post.Id;
        ViewData["PostSlug"] = Model.Post.Slug;
    }

    <!-- "Kommentieren" Button (visible by default) -->
    <button type="button" class="btn btn-primary mb-3" onclick="showCommentForm()">
        <i class="bi bi-chat-dots"></i> Kommentieren
    </button>

    @if (Model.Comments.Count == 0)
    {
        <p class="text-muted">No comments yet. Be the first to comment!</p>
    }
    else
    {
        <ul class="comment-thread">
            @await Html.PartialAsync("_CommentTree", Model.Comments)
        </ul>
    }

    <!-- Inline Top-Level Comment Form (hidden by default) -->
    <div id="commentFormContainer" class="card mb-4" style="display:none;">
        <div class="card-body">
            <form method="post" asp-page-handler="AddComment" id="mainCommentForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PostId" value="@Model.Post.Id" />
                <input type="hidden" name="PostSlug" value="@Model.Post.Slug" />
                <input type="hidden" name="ParentCommentId" value="" />

                @if (!User.Identity?.IsAuthenticated ?? true)
                {
                    <div class="row mb-2">
                        <div class="col-md-6">
                            <label class="form-label">Your Name *</label>
                            <input name="GuestName" class="form-control" required maxlength="100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Your Email *</label>
                            <input name="GuestEmail" type="email" class="form-control" required maxlength="200" />
                        </div>
                    </div>
                    <div class="alert alert-info small py-1">
                        <i class="bi bi-info-circle"></i> Guest comments require moderator approval before being visible.
                    </div>
                }

                <div class="mb-2">
                    <label class="form-label" id="commentFormLabel">Comment *</label>
                    <textarea name="Content" class="form-control" rows="3" required maxlength="5000"></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-send"></i> Post Comment</button>
                    <button type="button" class="btn btn-secondary btn-sm" onclick="hideCommentForm()">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</section>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Post</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this post? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page-handler="DeletePost" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="PostId" value="@Model.Post.Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hide all inline reply forms
        function hideAllReplyForms() {
            document.querySelectorAll('.inline-reply-form').forEach(el => el.style.display = 'none');
            document.getElementById('commentFormContainer').style.display = 'none';
        }

        // Show the top-level comment form
        function showCommentForm() {
            hideAllReplyForms();
            var form = document.getElementById('commentFormContainer');
            form.style.display = 'block';
            form.scrollIntoView({ behavior: 'smooth', block: 'center' });
            // Focus textarea
            var textarea = form.querySelector('textarea[name="Content"]');
            if (textarea) textarea.focus();
        }

        // Hide the top-level comment form
        function hideCommentForm() {
            document.getElementById('commentFormContainer').style.display = 'none';
        }

        // Show the reply form for a specific comment
        function showReplyForm(commentId) {
            hideAllReplyForms();
            var form = document.getElementById('replyForm-' + commentId);
            if (form) {
                form.style.display = 'block';
                form.scrollIntoView({ behavior: 'smooth', block: 'center' });
                var textarea = form.querySelector('textarea[name="Content"]');
                if (textarea) textarea.focus();
            }
        }

        // Hide the reply form for a specific comment
        function hideReplyForm(commentId) {
            var form = document.getElementById('replyForm-' + commentId);
            if (form) {
                form.style.display = 'none';
            }
        }

        // Voting functions
        function voteOnPost(postId, isUpvote) {
            fetch('/Posts/Detail?handler=VotePost&postId=' + postId + '&isUpvote=' + isUpvote, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': getAntiXsrfToken()
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    alert(data.error);
                    return;
                }
                document.getElementById('postUpvoteCount-' + postId).textContent = data.upvoteCount;
                document.getElementById('postDownvoteCount-' + postId).textContent = data.downvoteCount;
            })
            .catch(error => console.error('Vote error:', error));
        }

        function voteOnComment(commentId, isUpvote) {
            fetch('/Posts/Detail?handler=VoteComment&commentId=' + commentId + '&isUpvote=' + isUpvote, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': getAntiXsrfToken()
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    alert(data.error);
                    return;
                }
                document.getElementById('commentUpvoteCount-' + commentId).textContent = data.upvoteCount;
                document.getElementById('commentDownvoteCount-' + commentId).textContent = data.downvoteCount;
            })
            .catch(error => console.error('Vote error:', error));
        }

        // Get anti-CSRF token from the page
        function getAntiXsrfToken() {
            var tokens = document.getElementsByName('__RequestVerificationToken');
            if (tokens.length > 0) return tokens[0].value;
            return '';
        }
    </script>
}
